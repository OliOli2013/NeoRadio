#!/bin/sh
# NeoRadio 2.0 post-install cleanup.
# Clean only NeoRadio temporary installation/update files from /tmp.
for f in     /tmp/neoradio_update.ipk     /tmp/enigma2-plugin-extensions-neoradio*.ipk     /tmp/neoradio_repo*.tar.gz     /tmp/NeoRadio*.zip
 do
    [ -e "$f" ] && rm -f "$f"
 done
exit 0
